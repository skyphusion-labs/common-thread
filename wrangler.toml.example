# Common Thread Backend Worker configuration (EXAMPLE FILE)
#
# Copy this file to wrangler.toml and fill in the resource IDs.
#
# IMPORTANT BINDINGS (do not change these names):
#   - Hyperdrive (MySQL) → binding = "DB"
#   - R2 bucket          → binding = "ARCHIVE"

name = "common-thread"
main = "implementation/workers/index.ts"
compatibility_date = "2025-09-01"
compatibility_flags = ["nodejs_compat"]

# -----------------------------------------------------------------------------
# Before first use
# -----------------------------------------------------------------------------
# 1. Copy this file: cp wrangler.toml.example wrangler.toml
# 2. Create MySQL database and apply schema:
#      MYSQL_URL='mysql://USER:PASS@HOST:3306/common_thread' npm run db:migrate
# 3. Create Hyperdrive and paste the id below:
#      npm run db:hyperdrive:create -- 'mysql://USER:PASS@HOST:3306/common_thread'
# 4. Run: npm run r2:create
# -----------------------------------------------------------------------------

# =============================================================================
# Default / Local Development
# =============================================================================

[[hyperdrive]]
binding = "DB"
id = "YOUR_HYPERDRIVE_ID_HERE"
# localConnectionString = "mysql://user:password@localhost:3306/common_thread"

[[r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive"

[limits]
cpu_ms = 300000
subrequests = 50000

[vars]
ENVIRONMENT = "development"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"

# =============================================================================
# Explicit Development Environment (env.dev)
# =============================================================================

[env.dev]
name = "common-thread-dev"

[env.dev.limits]
cpu_ms = 300000
subrequests = 50000

[env.dev.vars]
ENVIRONMENT = "development"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"

[[env.dev.hyperdrive]]
binding = "DB"
id = "YOUR_DEV_HYPERDRIVE_ID_HERE"

[[env.dev.r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive-dev"

# =============================================================================
# Production Environment
# =============================================================================

[env.production]
name = "common-thread-prod"

[env.production.limits]
cpu_ms = 300000
subrequests = 50000

[env.production.vars]
ENVIRONMENT = "production"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"

[[env.production.hyperdrive]]
binding = "DB"
id = "YOUR_PROD_HYPERDRIVE_ID_HERE"

[[env.production.r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive-prod"

[observability.logs]
enabled = true
invocation_logs = true

# =============================================================================
# Service Bindings
# =============================================================================

[[services]]
binding = "WEB"
service = "common-thread-web"

[[env.dev.services]]
binding = "WEB"
service = "common-thread-web-dev"

[[env.production.services]]
binding = "WEB"
service = "common-thread-web-prod"

# =============================================================================
# Queues
# =============================================================================

# --- Default / Local ---
[[queues.producers]]
binding = "INGEST_QUEUE"
queue = "apify-ingest"

[[queues.consumers]]
queue = "apify-ingest"
max_batch_size = 5
max_batch_timeout = 30
max_concurrency = 2

# --- Development ---
[[env.dev.queues.producers]]
binding = "INGEST_QUEUE"
queue = "apify-ingest-dev"

[[env.dev.queues.consumers]]
queue = "apify-ingest-dev"
max_batch_size = 5
max_batch_timeout = 30
max_concurrency = 2

# --- Production ---
[[env.production.queues.producers]]
binding = "INGEST_QUEUE"
queue = "apify-ingest-prod"

[[env.production.queues.consumers]]
queue = "apify-ingest-prod"
max_batch_size = 2
max_batch_timeout = 10
max_concurrency = 30
max_retries = 3
retry_delay = 10000

# =============================================================================
# Workers VPC — self-hosted extraction container
# =============================================================================
# [[vpc_services]]
# binding = "VPC_INGEST"
# service_id = "YOUR_VPC_SERVICE_ID"
# remote = true
#
# [vars]
# INGEST_WORKER_URL = "http://common-thread-ingest.internal/trigger"
#
# wrangler secret put INGEST_SECRET

# =============================================================================
# Reasoner Secrets
# =============================================================================
#
# These should NOT be committed. Use .dev.vars locally and
# `wrangler secret put` in production.
#
# Required secrets:
#   AI_GATEWAY_URL
#   ANTHROPIC_API_KEY
#   INGEST_SECRET (when using VPC extraction container)
# -----------------------------------------------------------------------------
