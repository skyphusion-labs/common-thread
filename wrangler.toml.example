# Common Thread backend Worker (EXAMPLE)
#
# Copy to wrangler.toml and fill in resource IDs:
#   cp wrangler.toml.example wrangler.toml
#
# Required bindings (names must match code):
#   DB       — Hyperdrive → MySQL
#   ARCHIVE  — R2 bucket for content-addressed artifacts
#
# Optional (production ingest + PDF export):
#   VPC_INGEST, VPC_PDF, INGEST_WORKER_URL, PDF_WORKER_URL
#   Secrets: INGEST_SECRET, PDF_SECRET
#
# Attribution (server-side keys OR user BYOK from web UI):
#   Secrets: AI_GATEWAY_URL, ANTHROPIC_API_KEY (optional if all users BYOK)
#   Vars: AI_GATEWAY_ALLOWED_HOSTS (optional; default gateway.ai.cloudflare.com)
#   Var:  PUBLIC_BYOK_ONLY = "1" on the PUBLIC hosted Worker (#187) forces
#         visitor BYOK and ignores any server-side AI secret so it cannot be
#         ridden; credential-less attribution then returns 400 byok_required.

name = "common-thread"
main = "implementation/workers/index.ts"
compatibility_date = "2025-09-01"
compatibility_flags = ["nodejs_compat"]
preview_urls = false

[observability]
enabled = true

# =============================================================================
# Hyperdrive (MySQL)
# =============================================================================
# MYSQL_URL='mysql://USER:PASS@HOST:3306/common_thread' npm run db:migrate
# npm run db:hyperdrive:create -- 'mysql://USER:PASS@HOST:3306/common_thread'
#
# Workers VPC origin: if Hyperdrive points at MySQL through a Workers VPC service
# (Type TCP, e.g. host `mysql` port 3306), that VPC service's TLS cert-verification
# mode MUST be DISABLED. Workers VPC defaults to FULL verification, which rejects the
# MySQL container's cert and breaks Hyperdrive -> MySQL SILENTLY on (re)create. The
# toggle lives on the VPC service, not in mysql2/db.ts. See docs/SETUP.md section 2.

[[hyperdrive]]
binding = "DB"
id = "YOUR_HYPERDRIVE_ID_HERE"
# localConnectionString = "mysql://user:password@127.0.0.1:3306/common_thread"

# =============================================================================
# R2 archive
# =============================================================================
# npm run r2:create

[[r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive"

# Optional §5.4.4 dual-write replica (issue #154). Leave commented for the
# default single-bucket deploy. When both the binding and the var below are
# set, every archive put/delete mirrors to ARCHIVE_REPLICA.
# [[r2_buckets]]
# binding = "ARCHIVE_REPLICA"
# bucket_name = "common-thread-archive-replica"

# =============================================================================
# Durable Objects (manifest append serialization -- issue #70)
# =============================================================================
# MANIFEST_COORDINATOR serializes manifest appends per investigation so that
# concurrent ingests / extractor runs cannot drop chain-of-custody entries
# (the last-write-wins race). Optional: without this binding ManifestStore
# falls back to a non-serialized inline read-modify-write.
[[durable_objects.bindings]]
name = "MANIFEST_COORDINATOR"
class_name = "ManifestCoordinator"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["ManifestCoordinator"]

[limits]
cpu_ms = 300000
subrequests = 50000

[vars]
ENVIRONMENT = "development"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"
# Optional: "true" / "1" enables synchronous dual-write to ARCHIVE_REPLICA (§5.4.4).
# ARCHIVE_DUAL_WRITE = "true"
# Optional: "true" / "1" forces visitor BYOK and ignores server AI secrets (#187).
# Required on the public hosted Worker; leave unset for a self-host with server keys.
# PUBLIC_BYOK_ONLY = "1"
# Comma-separated browser origins allowed to call the API directly (empty = blocked).
# CORS_ALLOWED_ORIGINS = "http://127.0.0.1:8787,http://localhost:8787"

# Uncomment when Workers VPC containers are deployed (see docs/DEPLOYMENT.md):
# INGEST_WORKER_URL = "http://json-ingest:8080/trigger"
# PDF_WORKER_URL = "http://json-pdf:8081/render"
# PUBLIC_API_BASE_URL = "https://common-thread-backend.skyphusion.org"

# =============================================================================
# Workers VPC (optional — ingest + PDF containers)
# =============================================================================
# [[vpc_services]]
# binding = "VPC_INGEST"
# service_id = "YOUR_VPC_INGEST_SERVICE_ID"
# remote = true
#
# [[vpc_services]]
# binding = "VPC_PDF"
# service_id = "YOUR_VPC_PDF_SERVICE_ID"
# remote = true

# =============================================================================
# Development (env.dev)
# =============================================================================
[env.dev]
name = "common-thread-dev"

[env.dev.vars]
ENVIRONMENT = "development"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"
# INGEST_WORKER_URL = "http://json-ingest:8080/trigger"
# PDF_WORKER_URL = "http://json-pdf:8081/render"
# PUBLIC_API_BASE_URL = "https://common-thread-backend.skyphusion.org"

[[env.dev.hyperdrive]]
binding = "DB"
id = "YOUR_DEV_HYPERDRIVE_ID_HERE"

[[env.dev.r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive-dev"

[[env.dev.durable_objects.bindings]]
name = "MANIFEST_COORDINATOR"
class_name = "ManifestCoordinator"

[[env.dev.migrations]]
tag = "v1"
new_sqlite_classes = ["ManifestCoordinator"]

# [[env.dev.vpc_services]]
# binding = "VPC_INGEST"
# service_id = "YOUR_VPC_INGEST_SERVICE_ID"
# remote = true
#
# [[env.dev.vpc_services]]
# binding = "VPC_PDF"
# service_id = "YOUR_VPC_PDF_SERVICE_ID"
# remote = true

# =============================================================================
# Production (env.production)
# =============================================================================
[env.production]
name = "common-thread-prod"

# Optional when using a custom domain and you want to disable *.workers.dev:
# workers_dev = false

[[env.production.routes]]
pattern = "common-thread-backend.skyphusion.org"
custom_domain = true

[env.production.vars]
ENVIRONMENT = "production"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"
# Public hosted instance is BYOK-only (#187): server AI secrets, if any are
# ever set, are ignored and cannot be ridden. Credential-less attribution -> 400.
PUBLIC_BYOK_ONLY = "1"
# Browser origins approved for direct API use (comma-separated). Empty blocks all.
# CORS_ALLOWED_ORIGINS = "https://your-approved-app.example.com"
# INGEST_WORKER_URL = "http://json-ingest:8080/trigger"
# PDF_WORKER_URL = "http://json-pdf:8081/render"
# PUBLIC_API_BASE_URL = "https://common-thread-backend.skyphusion.org"

[[env.production.hyperdrive]]
binding = "DB"
id = "YOUR_PROD_HYPERDRIVE_ID_HERE"

[[env.production.r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive-prod"

[[env.production.durable_objects.bindings]]
name = "MANIFEST_COORDINATOR"
class_name = "ManifestCoordinator"

[[env.production.migrations]]
tag = "v1"
new_sqlite_classes = ["ManifestCoordinator"]

# [[env.production.vpc_services]]
# binding = "VPC_INGEST"
# service_id = "YOUR_VPC_INGEST_SERVICE_ID"
# remote = true
#
# [[env.production.vpc_services]]
# binding = "VPC_PDF"
# service_id = "YOUR_VPC_PDF_SERVICE_ID"
# remote = true

[observability.logs]
enabled = true
invocation_logs = true

[observability.traces]
enabled = true

# =============================================================================
# Secrets (never commit — use .dev.vars locally, wrangler secret put in prod)
# =============================================================================
# AI_GATEWAY_URL      — optional if users BYOK via web UI
# ANTHROPIC_API_KEY   — optional if users BYOK via web UI
# SIGNER_PUBLIC_KEY   — manifest verification
# SIGNER_PRIVATE_KEY  -- in-Worker Ed25519 evidence-packet signing (optional, 8.1.3);
#                        when unset, packets export unsigned. Never commit.
# SIGNER_ID           -- optional signer identity recorded in packet signatures
# INGEST_SECRET       — VPC ingest container auth (required with VPC_INGEST)
# PDF_SECRET          — VPC PDF container auth (?format=pdf)

# =============================================================================
# Operator (env.operator) -- account owner PRIVATE keyless attribution instance
# =============================================================================
# A separate, Cloudflare Access-gated operator backend so the account owner can
# run server-side attribution on a FUNDED Cloudflare AI Gateway (keyless Unified
# Billing: bills CF credits, needs zero Anthropic credits) WITHOUT re-opening
# credential-riding on the PUBLIC common-thread-prod Worker, which stays
# PUBLIC_BYOK_ONLY = "1" with its server AI secrets stripped (#187).
#
# Topology:
#   common-thread-ops.skyphusion.org  (OPS web, web env.operator, Access-gated)
#     -> [BACKEND service binding] -> common-thread-ops-backend  (THIS env)
#   The ops backend has NO public route; it is reachable ONLY through the web
#   Worker service binding (mirrors the prod web -> backend topology). This env
#   deliberately leaves PUBLIC_BYOK_ONLY UNSET, so credentials.ts resolves the
#   keyless server path (source: "environment", CF_AIG_TOKEN, #111). The PUBLIC
#   common-thread-prod Worker is UNAFFECTED by this env.
#
# Secrets (NEVER in this file; set via `wrangler secret put --env operator`):
#   AI_GATEWAY_URL  -- funded keyless CF AI Gateway base URL
#   CF_AIG_TOKEN    -- per-function AI Gateway Run token (keyless Unified Billing)
#
# DB + ARCHIVE reuse the production resources below (single operator; no public
# listing and capability-token scoping mean no cross-tenant exposure). The ops
# runbook documents the optional "isolate resources" hardening (own Hyperdrive
# + own R2 bucket) if fully separate operator storage is later wanted.
[env.operator]
name = "common-thread-ops-backend"

# NO [[env.operator.routes]] -- reachable ONLY via the web service binding.

[env.operator.vars]
ENVIRONMENT = "production"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"
# PUBLIC_BYOK_ONLY intentionally UNSET: this private instance runs keyless
# server-side attribution on the funded gateway. Do NOT set it here.

[[env.operator.hyperdrive]]
binding = "DB"
id = "YOUR_PROD_HYPERDRIVE_ID_HERE"

[[env.operator.r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive-prod"

[[env.operator.durable_objects.bindings]]
name = "MANIFEST_COORDINATOR"
class_name = "ManifestCoordinator"

[[env.operator.migrations]]
tag = "v1"
new_sqlite_classes = ["ManifestCoordinator"]
