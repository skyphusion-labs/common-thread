# Common Thread Backend Worker configuration (EXAMPLE FILE)
#
# Copy this file to wrangler.toml and fill in the resource IDs.
#
# IMPORTANT BINDINGS (do not change these names):
#   - D1 database → binding = "DB"
#   - R2 bucket   → binding = "ARCHIVE"
#
# After copying this file, run:
#   npm run db:create
#   npm run r2:create
#
# These commands will automatically populate the correct IDs while
# keeping the binding names as "DB" and "ARCHIVE".

name = "common-thread"
main = "implementation/workers/index.ts"
compatibility_date = "2025-09-01"
compatibility_flags = ["nodejs_compat"]

# Disable preview domains, enable them if you want them
preview_urls = false

# -----------------------------------------------------------------------------
# Before first use
# -----------------------------------------------------------------------------
# 1. Copy this file: cp wrangler.toml.example wrangler.toml
# 2. Run: npm run db:create
# 3. Run: npm run r2:create
# 4. Run: npm run db:migrate:local
# 5. (Optional) Run npm run keygen and add the public key to .dev.vars
# -----------------------------------------------------------------------------

# =============================================================================
# Default / Local Development
# =============================================================================

[[d1_databases]]
binding = "DB"
database_name = "common-thread"
database_id = "YOUR_D1_ID_HERE"
migrations_dir = "implementation/schema/migrations"

[[r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive"

[limits]
cpu_ms = 300000
subrequests = 50000

[vars]
ENVIRONMENT = "development"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"

# =============================================================================
# Explicit Development Environment (env.dev)
# =============================================================================

[env.dev]
name = "common-thread-dev"

[env.dev.limits]
cpu_ms = 300000
subrequests = 50000

[env.dev.vars]
ENVIRONMENT = "development"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"

[[env.dev.d1_databases]]
binding = "DB"
database_name = "common-thread-dev"
#database_id = "6d10a6f3-cd3d-441c-80a8-c242609b5226"
migrations_dir = "implementation/schema/migrations"

[[env.dev.r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive-dev"

# =============================================================================
# Production Environment
# =============================================================================

[env.production]
name = "common-thread-prod"

[env.production.limits]
cpu_ms = 300000
subrequests = 50000

[env.production.vars]
ENVIRONMENT = "production"
TRIAGE_MODEL = "claude-haiku-4-5"
REASONING_MODEL = "claude-opus-4-8"

[[env.production.d1_databases]]
binding = "DB"
database_name = "common-thread-prod"
database_id = "6bf375c2-6f52-4cd8-bc6e-04c53e21151b"
migrations_dir = "implementation/schema/migrations"

[[env.production.r2_buckets]]
binding = "ARCHIVE"
bucket_name = "common-thread-archive-prod"

[observability.logs]
enabled = true
invocation_logs = true

[observability.traces]
enabled = true

# =============================================================================
# Service Bindings
# =============================================================================

[[services]]
binding = "WEB"
service = "common-thread-web"

# INGEST_CONTAINER is commented out until the container is deployed
# [[services]]
# binding = "INGEST_CONTAINER"
# service = "apify-ingest-router"

[[env.dev.services]]
binding = "WEB"
service = "common-thread-web-dev"

# [[env.dev.services]]
# binding = "INGEST_CONTAINER"
# service = "apify-ingest-router-dev"

[[env.production.services]]
binding = "WEB"
service = "common-thread-web-prod"

# [[env.production.services]]
# binding = "INGEST_CONTAINER"
# service = "apify-ingest-router-prod"

# =============================================================================
# Queues
# =============================================================================

# --- Default / Local ---
[[queues.producers]]
binding = "INGEST_QUEUE"
queue = "apify-ingest"

[[queues.consumers]]
queue = "apify-ingest"
max_batch_size = 5
max_batch_timeout = 30
max_concurrency = 2

# --- Development ---
[[env.dev.queues.producers]]
binding = "INGEST_QUEUE"
queue = "apify-ingest-dev"

[[env.production.queues.consumers]]
queue = "apify-ingest-prod"
max_batch_size = 2              # Small batches are better for long-running heavy jobs
max_batch_timeout = 10
max_concurrency = 30            # Significantly increased from 2
max_retries = 3
retry_delay = 10000             # 10 seconds between retries

# --- Production ---
[[env.production.queues.producers]]
binding = "INGEST_QUEUE"
queue = "apify-ingest-prod"

[[env.production.queues.consumers]]
queue = "apify-ingest-prod"
max_batch_size = 5
max_batch_timeout = 30
max_concurrency = 2

# =============================================================================
# Reasoner Secrets
# =============================================================================
#
# These should NOT be committed. Use .dev.vars locally and
# `wrangler secret put` in production.
#
# Required secrets:
#   AI_GATEWAY_URL
#   ANTHROPIC_API_KEY
# -----------------------------------------------------------------------------
