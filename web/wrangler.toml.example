# Common Thread web frontend Worker (EXAMPLE)
#
# Copy to web/wrangler.toml:
#   cp web/wrangler.toml.example web/wrangler.toml
#
# The web worker serves the browser UI and proxies API calls to the backend.
# Deploy the backend first, then set service bindings below.

name = "common-thread-web"
main = "worker.js"
compatibility_date = "2025-09-01"
preview_urls = false

[observability]
enabled = true

[observability.logs]
enabled = true
invocation_logs = true

# Fallback when no service binding (local dev or misconfigured binding)
[vars]
# DEFAULT_BACKEND_URL = "http://127.0.0.1:8787"
#
# Backend override policy (resolveBackend in worker.js, issue #66):
# The UI 'Backend URL' field sends ?backend=<url> to the /api/proxy route. With
# the BACKEND service binding set (hosted deploys), any override is rejected with
# an explicit 400. With no binding, an override is honored ONLY if its origin is a
# loopback dev address (http://127.0.0.1:*, http://localhost:*) or listed below.
# Credentials (authorization, x-anthropic-api-key, x-investigation-token) are only
# forwarded to such a trusted target. Leave unset in production. Comma-separated:
# BACKEND_ORIGIN_ALLOWLIST = "https://common-thread-dev.example.workers.dev"

# =============================================================================
# Service bindings → backend Worker
# =============================================================================
# Binding name in web/worker.js: env.BACKEND
# Service name must match the deployed backend Worker name exactly.

[[services]]
binding = "BACKEND"
service = "common-thread"

[env.dev]
name = "common-thread-web-dev"

[env.dev.vars]
# DEFAULT_BACKEND_URL = "https://common-thread-dev.<your-subdomain>.workers.dev"

[[env.dev.services]]
binding = "BACKEND"
service = "common-thread-dev"

[env.production]
name = "common-thread-web-prod"

# Optional when using a custom domain and you want to disable *.workers.dev:
# workers_dev = false

[env.production.vars]
PUBLIC_URL = "https://common-thread.skyphusion.org"
# PUBLIC_BYOK_ONLY gates attribution to bring-your-own-key on the PUBLIC instance:
# the UI disables Run attribution and shows a clear error until the visitor sets
# their own AI Gateway URL + Anthropic key, and never advertises a host-funded
# path. Set to "true" for the hosted deploy. Leave unset for self-host, where the
# backend may supply AI_GATEWAY_URL + CF_AIG_TOKEN/ANTHROPIC_API_KEY as secrets.
PUBLIC_BYOK_ONLY = "true"
# DEFAULT_BACKEND_URL only if BACKEND service binding is unavailable

[[env.production.routes]]
pattern = "common-thread.skyphusion.org"
custom_domain = true

[[env.production.services]]
binding = "BACKEND"
service = "common-thread-prod"
