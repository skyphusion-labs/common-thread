# web/wrangler.toml.example
#
# Copy this to web/wrangler.toml and customize for your deployment.
# The real web/wrangler.toml is in .gitignore — never commit it.
#
# This configures the self-contained web frontend Worker.

name = "common-thread-web"
main = "worker.js"
compatibility_date = "2025-06-17"

# Fallback backend URL (used when no service binding is available)
[vars]
# DEFAULT_BACKEND_URL = "https://common-thread-web.your-subdomain.workers.dev"

# =============================================================================
# Service Bindings
# =============================================================================
#
# Service bindings are non-inheritable, so they must be declared separately
# for each environment.
#
# The web frontend uses the binding name "BACKEND" to talk to the main backend.

# --- Development (default / top level) ---
[[services]]
binding = "BACKEND"
service = "common-thread"

# --- Explicit dev environment ---
[env.dev]
name = "common-thread-web-dev"

[env.dev.vars]
# DEFAULT_BACKEND_URL = "https://common-thread-web-dev.your-subdomain.workers.dev"

[[env.dev.services]]
binding = "BACKEND"
service = "common-thread-dev"

# --- Production ---
[env.production]
name = "common-thread-web-prod"

[env.production.vars]
# DEFAULT_BACKEND_URL = "https://common-thread-web-prod.your-subdomain.workers.dev"

[[env.production.services]]
binding = "BACKEND"
service = "common-thread-prod"

# =============================================================================
# Observability
# =============================================================================
[observability.logs]
enabled = true
invocation_logs = true
