{
  "name": "common-thread",
  "version": "0.1.0",
  "private": true,
  "description": "Methodology and reference implementation for sockpuppet attribution from public behavioral signals on social platforms.",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/skyphusion-labs/common-thread",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyphusion-labs/common-thread.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "deploy:backend:dev": "node scripts/deploy-backend.js --env=dev",
    "deploy:backend:prod": "node scripts/deploy-backend.js --env=production",
    "deploy:web:dev": "node scripts/deploy-web.js --env=dev",
    "deploy:web:prod": "node scripts/deploy-web.js --env=production",
    "deploy:all:dev": "npm run deploy:backend:dev && npm run deploy:web:dev",
    "deploy:all:prod": "npm run deploy:backend:prod && npm run deploy:web:prod",
    "dev:web": "wrangler dev --config web/wrangler.toml",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node scripts/apply-mysql-schema.mjs",
    "db:hyperdrive:create": "wrangler hyperdrive create common-thread --connection-string",
    "r2:create": "wrangler r2 bucket create common-thread-archive --binding ARCHIVE --update-config",
    "r2:create:prod": "wrangler r2 bucket create common-thread-archive-prod --binding ARCHIVE --env production --update-config",
    "keygen": "node scripts/keygen.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
    "marked": "^18.0.5",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20260616.1",
    "@vitest/coverage-istanbul": "^4.1.10",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "undici": "^8.7.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.102.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
