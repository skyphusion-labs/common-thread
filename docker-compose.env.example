# Copy to .env in the repository root:
#   cp docker-compose.env.example .env
#
# Every value below without a default in docker-compose.yml is REQUIRED: the
# stack will refuse to start if it is unset (no weak fallbacks). Generate the
# secrets with e.g. `openssl rand -hex 32`; do not ship these placeholders.

# MySQL (all three credentials are required; pick strong unique values)
MYSQL_ROOT_PASSWORD=change-me-to-a-long-random-string
MYSQL_USER=commonthread
MYSQL_PASSWORD=change-me-to-a-different-long-random-string
MYSQL_DATABASE=common_thread

# Required -- shared bearer token; must match wrangler secret INGEST_SECRET on the Worker
INGEST_SECRET=change-me-to-a-long-random-string

# PDF container -- must match wrangler secret PDF_SECRET on the Worker
PDF_SECRET=change-me-to-a-different-long-random-string

# Cloudflare R2 (S3-compatible API credentials for the archive bucket)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=common-thread-archive

# No host ports: nothing is published to the box. The Worker reaches the
# containers and MySQL over the cloudflared VPC connector on the compose network.
# If you ever need a host-local debug port, bind loopback explicitly in
# docker-compose.yml (e.g. 127.0.0.1:3306:3306), never the bare 3306:3306 form.
