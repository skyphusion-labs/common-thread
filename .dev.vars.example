# Common Thread local development secrets.
#
# Copy this file to .dev.vars (which is gitignored) and fill in your values.
# Wrangler will load these as Worker env vars when running `wrangler dev`.
#
# For production secrets, use:
#   wrangler secret put SIGNER_PUBLIC_KEY --env production

# Public key of the practitioner authorized to sign manifests for this
# investigation. Generate a keypair with `npm run keygen` and paste the
# public key here. The private key is stored separately (password manager,
# hardware key) and never enters the Worker.
SIGNER_PUBLIC_KEY=

# Optional: investigation-scoped identifier shown in API responses.
INVESTIGATION_NAMESPACE=local-dev

# Optional: server-side attribution (skip if all users BYOK via web UI)
# AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/ACCOUNT/GATEWAY/anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Required for VPC ingest container delegation.
# Must match INGEST_SECRET on the json-ingest container.
INGEST_SECRET=

# Required for evidence-packet PDF export (?format=pdf) via VPC PDF container.
# Must match PDF_SECRET on the json-pdf container.
PDF_SECRET=
